// Categories for grouping
const categories = [...new Set(presets.map(p => p.category))];

const systemFonts = ['Segoe UI Variable', 'Adobe Clean', 'Georgia'];

const googleFonts = [...new Set(presets.flatMap(p => [p.heading, p.body, p.code]))].filter(f => !systemFonts.includes(f));
const fontsUrl = `https://fonts.googleapis.com/css2?${googleFonts.map(f => `family=${f.replace(/ /g, '+')}`).join('&')}&display=swap`;

function toFontId(family: string): string {
  return family.toLowerCase().replace(/ /g, '-');
}

function isLinkable(family: string): boolean {
  return !systemFonts.includes(family);
}

function getPresetName(id: string): string {
  return presets.find(p => p.id === id)?.name ?? id;
}
---

<BaseLayout
  title="Typography Presets"
  site="www"
  currentPath="/presets"
  description="100 curated typography presets for design systems."
>
  <SEOHead
    slot="head"
    title="Typography Presets — Fetchtype"
    description="100 curated typography presets organized by use case: general purpose, editorial, application UI, e-commerce, documentation, design systems, and creative. Each preset includes font stacks, size scales, layout guidance, and color pairings."
    canonicalUrl="https://fetchtype.com/presets"
    ogType="website"
  />

  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontsUrl} rel="stylesheet" />
  </Fragment>

  <!-- Hero -->
  <section class="max-w-[1400px] mx-auto px-6 pt-16 pb-12">
    <div class="max-w-3xl">
      <p class="font-mono text-xs text-ft-muted uppercase tracking-[0.15em] mb-6">
        Design System Presets
      </p>

      <h1 class="font-display text-6xl md:text-7xl leading-[0.93] tracking-tight text-ft-dark mb-8">
        Presets
      </h1>

      <p class="font-body text-lg leading-relaxed text-ft-muted max-w-xl mb-6">
        {presets.length} curated typography configurations organized by use case. Each preset includes font stacks,
        size relationships, layout guidance, color pairings, and style direction.
      </p>

      <!-- Category quick nav -->
      <div class="flex flex-wrap gap-2">
        {categories.map(cat => (
          <a
            href={`#cat-${cat.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
            class="font-mono text-xs text-ft-muted border border-thin px-3 py-1.5 hover:text-ft-dark hover:border-ft-dark transition-colors uppercase tracking-wider"
          >
            {cat}
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="border-t border-thin"></div>

  <!-- Preset list by category -->
  {categories.map(cat => {
    const catPresets = presets.filter(p => p.category === cat);
    const catSlug = cat.toLowerCase().replace(/[^a-z0-9]+/g, '-');
    return (
      <section id={`cat-${catSlug}`} class="max-w-[1400px] mx-auto px-6 pt-12">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="font-display text-2xl text-ft-dark tracking-tight">{cat}</h2>
          <span class="font-mono text-xs text-ft-muted border border-thin px-2 py-0.5">{catPresets.length}</span>
        </div>

        {catPresets.map((preset, i) => (
          <article id={preset.id} class="mb-16 last:mb-0">

            <!-- Header row -->
            <div class="flex items-baseline gap-4 mb-2">
              <span class="font-mono text-sm text-ft-accent">
                {String(presets.indexOf(preset) + 1).padStart(2, '0')}
              </span>
              <h3 class="font-display text-3xl md:text-4xl text-ft-dark tracking-tight">
                {preset.name}
              </h3>
            </div>

            <p class="font-body text-base text-ft-muted leading-relaxed mb-4 max-w-2xl">
              {preset.description}
            </p>

            <!-- Style prompt -->
            <div class="bg-ft-surface border border-thin px-5 py-4 mb-6 max-w-3xl">
              <p class="font-mono text-[10px] text-ft-accent uppercase tracking-wider mb-2">Style Direction</p>
              <p class="font-body text-sm text-ft-dark leading-relaxed">{preset.stylePrompt}</p>
            </div>

            <!-- Three-column: Font stack, Sizes, Colors -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-ft-border mb-6">
              <!-- Font stack -->
              <div class="bg-ft-cream p-5">
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-3">Font Stack</p>
                <div class="flex flex-col gap-2">
                  <div>
                    <span class="font-mono text-[10px] text-ft-muted">Heading</span>
                    {isLinkable(preset.heading) ? (
                      <a href={`https://registry.fetchtype.com/${toFontId(preset.heading)}`} class="block font-body text-sm text-ft-dark underline underline-offset-2 hover:text-ft-accent transition-colors">
                        {preset.heading}
                      </a>
                    ) : (
                      <p class="font-body text-sm text-ft-dark">{preset.heading}</p>
                    )}
                  </div>
                  <div>
                    <span class="font-mono text-[10px] text-ft-muted">Body</span>
                    {isLinkable(preset.body) ? (
                      <a href={`https://registry.fetchtype.com/${toFontId(preset.body)}`} class="block font-body text-sm text-ft-dark underline underline-offset-2 hover:text-ft-accent transition-colors">
                        {preset.body}
                      </a>
                    ) : (
                      <p class="font-body text-sm text-ft-dark">{preset.body}</p>
                    )}
                  </div>
                  <div>
                    <span class="font-mono text-[10px] text-ft-muted">Mono</span>
                    {isLinkable(preset.code) ? (
                      <a href={`https://registry.fetchtype.com/${toFontId(preset.code)}`} class="block font-body text-sm text-ft-dark underline underline-offset-2 hover:text-ft-accent transition-colors">
                        {preset.code}
                      </a>
                    ) : (
                      <p class="font-body text-sm text-ft-dark">{preset.code}</p>
                    )}
                  </div>
                  <div>
                    <span class="font-mono text-[10px] text-ft-muted">Scale</span>
                    <p class="font-body text-sm text-ft-dark">{preset.scale}</p>
                  </div>
                </div>
              </div>

              <!-- Size relationships -->
              <div class="bg-ft-cream p-5">
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-3">Size Relationships</p>
                <div class="flex flex-col gap-2">
                  <div class="flex justify-between">
                    <span class="font-mono text-[10px] text-ft-muted">H1</span>
                    <span class="font-mono text-sm text-ft-dark">{preset.sizes.h1}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="font-mono text-[10px] text-ft-muted">Body</span>
                    <span class="font-mono text-sm text-ft-dark">{preset.sizes.body}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="font-mono text-[10px] text-ft-muted">Caption</span>
                    <span class="font-mono text-sm text-ft-dark">{preset.sizes.caption}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="font-mono text-[10px] text-ft-muted">Line Height</span>
                    <span class="font-mono text-sm text-ft-dark">{preset.sizes.lineHeight}</span>
                  </div>
                </div>
              </div>

              <!-- Colors -->
              <div class="bg-ft-cream p-5">
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-3">Color Direction</p>
                <div class="flex flex-col gap-2">
                  <div class="flex items-center gap-2">
                    <span class="w-4 h-4 border border-thin flex-shrink-0" style={`background: ${preset.colors.bg};`}></span>
                    <span class="font-mono text-[10px] text-ft-muted">Background</span>
                    <span class="font-mono text-xs text-ft-dark ml-auto">{preset.colors.bg}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="w-4 h-4 border border-thin flex-shrink-0" style={`background: ${preset.colors.primary};`}></span>
                    <span class="font-mono text-[10px] text-ft-muted">Primary</span>
                    <span class="font-mono text-xs text-ft-dark ml-auto">{preset.colors.primary}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="w-4 h-4 border border-thin flex-shrink-0" style={`background: ${preset.colors.accent};`}></span>
                    <span class="font-mono text-[10px] text-ft-muted">Accent</span>
                    <span class="font-mono text-xs text-ft-dark ml-auto">{preset.colors.accent}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="w-4 h-4 border border-thin flex-shrink-0" style={`background: ${preset.colors.text};`}></span>
                    <span class="font-mono text-[10px] text-ft-muted">Body text</span>
                    <span class="font-mono text-xs text-ft-dark ml-auto">{preset.colors.text}</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Layout guidance -->
            <div class="bg-ft-surface border border-thin px-5 py-4 mb-6 max-w-3xl">
              <p class="font-mono text-[10px] text-ft-accent uppercase tracking-wider mb-2">Layout Guidance</p>
              <p class="font-body text-sm text-ft-dark leading-relaxed">{preset.layout}</p>
            </div>

            <!-- Imagery guidance -->
            <div class="bg-ft-surface border border-thin px-5 py-4 mb-6 max-w-3xl">
              <p class="font-mono text-[10px] text-ft-accent uppercase tracking-wider mb-2">Image Pairing</p>
              <p class="font-body text-sm text-ft-dark leading-relaxed">{preset.imagery}</p>
            </div>

            <!-- Similar / Contrast -->
            <div class="flex flex-wrap gap-6 mb-6">
              <div>
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Similar presets</p>
                <div class="flex gap-1.5">
                  {preset.similarTo.map(id => (
                    <a href={`#${id}`} class="font-mono text-xs text-ft-dark border border-thin px-2 py-1 hover:bg-ft-surface transition-colors">
                      {getPresetName(id)}
                    </a>
                  ))}
                </div>
              </div>
              <div>
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Contrast with</p>
                <div class="flex gap-1.5">
                  {preset.contrastWith.map(id => (
                    <a href={`#${id}`} class="font-mono text-xs text-ft-muted border border-thin px-2 py-1 hover:bg-ft-surface transition-colors">
                      {getPresetName(id)}
                    </a>
                  ))}
                </div>
              </div>
            </div>

            <!-- Type specimen -->
            <div class="border border-thin mb-4 bg-white overflow-hidden" style={`background: ${preset.colors.bg};`}>
              <div class="p-6 md:p-8">
                <p
                  class="tracking-tight mb-4"
                  style={`font-family: '${preset.heading}', sans-serif; font-size: ${preset.sizes.h1.split(' / ')[0]}; color: ${preset.colors.primary}; line-height: 1.1;`}
                >
                  The quick brown fox
                </p>
                <p
                  class="leading-relaxed mb-4 max-w-xl"
                  style={`font-family: '${preset.body}', sans-serif; font-size: ${preset.sizes.body.split(' / ')[0]}; color: ${preset.colors.text}; line-height: ${preset.sizes.lineHeight};`}
                >
                  Typography is the art and technique of arranging type to make written language legible, readable, and appealing when displayed. The arrangement of type involves selecting typefaces, point sizes, line lengths, line-spacing, and letter-spacing.
                </p>
                <code
                  class="text-sm"
                  style={`font-family: '${preset.code}', monospace; color: ${preset.colors.accent};`}
                >
                  fetchtype init --preset {preset.id}
                </code>
              </div>
            </div>

            <!-- Usage code block -->
            <div class="bg-ft-code-bg px-5 py-4 font-mono text-sm text-white overflow-x-auto">
              <span class="text-ft-muted">$</span> npx fetchtype init --preset {preset.id}
            </div>

            {i < catPresets.length - 1 && (
              <div class="border-b border-thin mt-16"></div>
            )}
          </article>
        ))}

        <div class="border-b border-thin mt-8 mb-0"></div>
      </section>
    );
  })}

  <!-- Footer CTA -->
  <section class="max-w-[1400px] mx-auto px-6 py-16">
    <div class="max-w-2xl">
      <p class="font-mono text-xs text-ft-muted uppercase tracking-[0.15em] mb-4">Custom Presets</p>
      <h2 class="font-display text-3xl text-ft-dark tracking-tight mb-4">
        Build your own
      </h2>
      <p class="font-body text-base text-ft-muted leading-relaxed mb-6">
        Presets are just token files. Create a <code class="font-mono text-sm">fetchtype.tokens.json</code> with your
        own fonts, sizes, and colors — then share it with your team via <code class="font-mono text-sm">.fetchtype.json</code> config.
      </p>
      <div class="bg-ft-code-bg px-5 py-4 font-mono text-sm text-white overflow-x-auto">
        <span class="text-ft-muted">$</span> npx fetchtype init --prompt "modern fintech dashboard with dark mode"
      </div>
    </div>
  </section>
</BaseLayout>
