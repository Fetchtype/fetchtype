---
import BaseLayout from '@fetchtype/ui/src/components/BaseLayout.astro';
import '../styles/global.css';

const mcpTools = [
  'validate_tokens',
  'resolve_font',
  'suggest_fonts',
  'pair_fonts',
  'get_fallback_css',
  'list_presets',
  'get_preset',
  'build_tokens',
  'search_registry',
  'audit_codebase',
  'prepare_fonts',
  'get_systems',
];

const presets = [
  { name: 'base',       font: 'Inter' },
  { name: 'editorial',  font: 'Georgia' },
  { name: 'dashboard',  font: 'Inter' },
  { name: 'ecommerce',  font: 'DM Sans' },
  { name: 'docs',       font: 'Source Serif 4' },
  { name: 'fluent',     font: 'Segoe UI Variable' },
  { name: 'material',   font: 'Roboto' },
  { name: 'carbon',     font: 'IBM Plex Sans' },
  { name: 'spectrum',   font: 'Adobe Clean' },
  { name: 'radix',      font: 'Inter' },
];
---

<BaseLayout title="Typography Infrastructure" site="www" currentPath="/">

  <!-- ═══════════════════════════════════════════════
       ACT 1: HERO
       ═══════════════════════════════════════════════ -->
  <section class="max-w-[1400px] mx-auto px-6 pt-16 pb-12">
    <div class="max-w-3xl">
      <p class="font-mono text-xs text-ft-muted uppercase tracking-[0.15em] mb-6">
        Typography Infrastructure
      </p>

      <h1 class="font-display text-6xl md:text-7xl leading-[0.93] tracking-tight text-ft-dark mb-8">
        Most of what your<br />users do is&nbsp;read
      </h1>

      <p class="font-body text-lg leading-relaxed text-ft-text max-w-xl mb-10">
        Fetchtype is the typography layer for agent-native development.
        Validate tokens, resolve fonts, generate fallback CSS — from your
        CLI or any AI agent.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <div class="inline-flex items-center bg-ft-code-bg text-white px-5 py-3 font-mono text-sm border border-ft-code-bg">
          <span class="text-ft-muted mr-2">$</span>npx fetchtype init
        </div>
        <a
          href="/registry"
          class="inline-flex items-center justify-center bg-ft-accent text-white px-6 py-3 font-mono text-sm uppercase tracking-wider hover:bg-ft-accent-hover transition-colors"
        >
          Browse Registry →
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-thin">
    <div class="max-w-[1400px] mx-auto px-6 py-8 grid grid-cols-2 md:grid-cols-4 gap-px bg-ft-border">
      <div class="bg-ft-cream px-6 py-2">
        <p class="font-display text-4xl text-ft-dark">1,929</p>
        <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mt-1">Fonts</p>
      </div>
      <div class="bg-ft-cream px-6 py-2">
        <p class="font-display text-4xl text-ft-dark">20</p>
        <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mt-1">Validation Rules</p>
      </div>
      <div class="bg-ft-cream px-6 py-2">
        <p class="font-display text-4xl text-ft-dark">12</p>
        <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mt-1">MCP Tools</p>
      </div>
      <div class="bg-ft-cream px-6 py-2">
        <p class="font-display text-4xl text-ft-dark">10</p>
        <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mt-1">Presets</p>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       ACT 2: THREE PILLARS
       ═══════════════════════════════════════════════ -->
  <section class="max-w-[1400px] mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-px bg-ft-border">

      <!-- 01 — Verify -->
      <div class="bg-ft-cream p-8 flex flex-col">
        <p class="font-mono text-xs text-ft-accent uppercase tracking-wider mb-5">01 — Verify</p>
        <h2 class="font-display text-2xl text-ft-dark mb-3">Validate typography tokens</h2>
        <p class="font-body text-sm leading-relaxed text-ft-muted mb-8">
          20 rules covering WCAG contrast ratios, line-height floors,
          heading hierarchy, spacing monotonicity, and dark-mode
          completeness. Block bad tokens in CI before they ship.
        </p>
        <div class="mt-auto bg-ft-code-bg text-white p-5 font-mono text-xs leading-relaxed overflow-x-auto">
          <div class="text-ft-muted mb-3">$ fetchtype validate -i tokens.json</div>
          <div class="space-y-1">
            <div><span class="text-green-400">✓</span> contrast-ratio&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-ft-muted">4.87:1 (AA pass)</span></div>
            <div><span class="text-green-400">✓</span> body-line-height&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-ft-muted">1.6 (≥ 1.4)</span></div>
            <div><span class="text-green-400">✓</span> heading-hierarchy&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-ft-muted">h1 &gt; h2 &gt; h3 &gt; h4</span></div>
            <div><span class="text-green-400">✓</span> spacing-monotonic&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-ft-muted">xs &lt; sm &lt; md &lt; lg</span></div>
            <div><span class="text-yellow-400">⚠</span> caption-min-size&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-ft-muted">0.75rem (suggest ≥ 0.8125rem)</span></div>
          </div>
          <div class="mt-4 pt-4 border-t border-white/10 text-ft-muted">
            12 passed · 1 warning · 0 errors
          </div>
        </div>
      </div>

      <!-- 02 — Resolve -->
      <div class="bg-ft-cream p-8 flex flex-col">
        <p class="font-mono text-xs text-ft-accent uppercase tracking-wider mb-5">02 — Resolve</p>
        <h2 class="font-display text-2xl text-ft-dark mb-3">Font intelligence at your fingertips</h2>
        <p class="font-body text-sm leading-relaxed text-ft-muted mb-8">
          1,929 fonts with metrics, context scores, and pairing
          recommendations. Generate platform-aware fallback CSS for
          5 rendering targets with a single command.
        </p>
        <div class="mt-auto bg-ft-code-bg text-white p-5 font-mono text-xs leading-relaxed overflow-x-auto">
          <div class="text-ft-muted mb-3">$ fetchtype resolve inter --css</div>
          <div class="space-y-1 mb-3">
            <div>Inter (sans-serif) — Variable</div>
            <div class="text-ft-muted">9 weights · 7 subsets · 31.3 KB</div>
            <div class="text-ft-muted">Context: interface (95%) · reading (75%)</div>
          </div>
          <div class="text-ft-muted mb-2">Fallback CSS generated for 5 targets:</div>
          <div class="space-y-1">
            <div><span class="text-green-400">✓</span> apple&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ <span class="text-ft-muted">SF Pro (size-adjust: 100.4%)</span></div>
            <div><span class="text-green-400">✓</span> windows&nbsp;&nbsp;→ <span class="text-ft-muted">Segoe UI (size-adjust: 100.7%)</span></div>
            <div><span class="text-green-400">✓</span> android&nbsp;&nbsp;→ <span class="text-ft-muted">Roboto (size-adjust: 100.2%)</span></div>
            <div><span class="text-green-400">✓</span> linux&nbsp;&nbsp;&nbsp;&nbsp;→ <span class="text-ft-muted">Noto Sans (size-adjust: 99.8%)</span></div>
            <div><span class="text-green-400">✓</span> universal→ <span class="text-ft-muted">Arial (size-adjust: 101.1%)</span></div>
          </div>
        </div>
      </div>

      <!-- 03 — Deploy -->
      <div class="bg-ft-cream p-8 flex flex-col">
        <p class="font-mono text-xs text-ft-accent uppercase tracking-wider mb-5">03 — Deploy</p>
        <h2 class="font-display text-2xl text-ft-dark mb-3">Export to any stack</h2>
        <p class="font-body text-sm leading-relaxed text-ft-muted mb-8">
          One token file, every format. CSS custom properties, Tailwind
          config, shadcn theme, and W3C Design Tokens — generated in a
          single build step.
        </p>
        <div class="mt-auto bg-ft-code-bg text-white p-5 font-mono text-xs leading-relaxed overflow-x-auto">
          <div class="text-ft-muted mb-3">$ fetchtype build -i tokens.json -o dist/</div>
          <div class="space-y-1">
            <div>→ <span class="text-green-400">dist/tokens.css</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-ft-muted">2.1 KB</span></div>
            <div>→ <span class="text-green-400">dist/tokens.json</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-ft-muted">1.8 KB</span></div>
            <div>→ <span class="text-green-400">dist/tailwind.config.ts</span>&nbsp;&nbsp;<span class="text-ft-muted">3.2 KB</span></div>
            <div>→ <span class="text-green-400">dist/tokens.w3c.json</span>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-ft-muted">2.4 KB</span></div>
          </div>
          <div class="mt-4 pt-4 border-t border-white/10 text-ft-muted">
            4 files written
          </div>
        </div>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       ACT 3: AGENT-NATIVE
       ═══════════════════════════════════════════════ -->
  <section class="border-t border-thin bg-ft-surface">
    <div class="max-w-[1400px] mx-auto px-6 py-16">

      <div class="grid md:grid-cols-2 gap-16 items-start">

        <!-- Left: copy -->
        <div>
          <p class="font-mono text-xs text-ft-muted uppercase tracking-[0.15em] mb-6">Agent-Native</p>
          <h2 class="font-display text-4xl md:text-5xl text-ft-dark leading-[0.95] tracking-tight mb-6">
            Built for AI agents,<br />not just humans
          </h2>
          <p class="font-body text-base leading-relaxed text-ft-text mb-8 max-w-md">
            12 MCP tools. Works with Claude, Cursor, Windsurf, Cline, and
            any MCP-compatible client. Add fetchtype to your agent's
            context and it can validate, resolve, and export typography
            without leaving the conversation.
          </p>

          <!-- MCP tool badges -->
          <div class="flex flex-wrap gap-2">
            {mcpTools.map((tool) => (
              <span class="font-mono text-xs text-ft-dark border border-thin px-3 py-1.5 bg-ft-cream">
                {tool}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: MCP config block -->
        <div>
          <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mb-3">
            Add to your MCP config
          </p>
          <div class="bg-ft-code-bg text-white p-6 font-mono text-sm leading-relaxed">
            <pre class="whitespace-pre overflow-x-auto"><code>{`{
  "mcpServers": {
    "fetchtype": {
      "command": "npx",
      "args": ["fetchtype", "mcp"]
    }
  }
}`}</code></pre>
          </div>
          <p class="font-mono text-xs text-ft-muted mt-4">
            Compatible with Claude Desktop · Cursor · Windsurf · Cline · Continue
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       ACT 4: GET STARTED
       ═══════════════════════════════════════════════ -->
  <section class="border-t border-thin">
    <div class="max-w-[1400px] mx-auto px-6 py-16">

      <p class="font-mono text-xs text-ft-muted uppercase tracking-[0.15em] mb-6">Get Started</p>
      <h2 class="font-display text-4xl md:text-5xl text-ft-dark leading-[0.95] tracking-tight mb-10">
        Three commands to<br />validated typography
      </h2>

      <!-- Three commands -->
      <div class="grid md:grid-cols-3 gap-px bg-ft-border mb-16">

        <div class="bg-ft-cream p-6">
          <p class="font-mono text-xs text-ft-accent uppercase tracking-wider mb-4">Step 1 — Init</p>
          <div class="bg-ft-code-bg text-white px-4 py-3 font-mono text-sm">
            <span class="text-ft-muted">$</span> npx fetchtype init
          </div>
          <p class="font-body text-xs text-ft-muted mt-3 leading-relaxed">
            Scaffold a <code class="font-mono">fetchtype.tokens.json</code> from a preset,
            or bring your own token file.
          </p>
        </div>

        <div class="bg-ft-cream p-6">
          <p class="font-mono text-xs text-ft-accent uppercase tracking-wider mb-4">Step 2 — Validate</p>
          <div class="bg-ft-code-bg text-white px-4 py-3 font-mono text-sm">
            <span class="text-ft-muted">$</span> npx fetchtype validate -i fetchtype.tokens.json
          </div>
          <p class="font-body text-xs text-ft-muted mt-3 leading-relaxed">
            Run all 20 rules. Exit 1 on errors — safe to gate in CI.
          </p>
        </div>

        <div class="bg-ft-cream p-6">
          <p class="font-mono text-xs text-ft-accent uppercase tracking-wider mb-4">Step 3 — Build</p>
          <div class="bg-ft-code-bg text-white px-4 py-3 font-mono text-sm">
            <span class="text-ft-muted">$</span> npx fetchtype build -i fetchtype.tokens.json -o dist/
          </div>
          <p class="font-body text-xs text-ft-muted mt-3 leading-relaxed">
            Emit CSS, Tailwind, shadcn, and W3C token files in one pass.
          </p>
        </div>

      </div>

      <!-- Preset selector -->
      <div class="mb-16">
        <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mb-5">
          10 presets included
        </p>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-px bg-ft-border">
          {presets.map((preset) => (
            <a href={`/presets#${preset.name}`} class="bg-ft-cream p-5 border-thin hover:bg-white transition-colors block">
              <p class="font-mono text-xs text-ft-accent uppercase tracking-wider mb-2">{preset.name}</p>
              <p class="font-body text-sm text-ft-dark">{preset.font}</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Footer CTA -->
      <div class="border-t border-thin pt-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="font-body text-sm text-ft-muted max-w-sm leading-relaxed">
          Full API reference, MCP tool documentation, and integration
          guides live on fetchtype.dev.
        </p>
        <div class="flex gap-3">
          <a
            href="https://fetchtype.dev"
            class="font-mono text-xs uppercase tracking-wider border border-thin px-5 py-3 text-ft-dark hover:bg-ft-surface transition-colors"
          >
            Read the Docs →
          </a>
          <a
            href="https://github.com/fetchtype/fetchtype"
            class="font-mono text-xs uppercase tracking-wider border border-thin px-5 py-3 text-ft-dark hover:bg-ft-surface transition-colors"
          >
            GitHub →
          </a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
