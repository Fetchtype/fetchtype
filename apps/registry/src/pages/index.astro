---
import BaseLayout from '@fetchtype/ui/src/components/BaseLayout.astro';
import SEOHead from '@fetchtype/ui/src/components/SEOHead.astro';
import '../styles/global.css';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

// Read registry at build time
const registryPath = resolve(process.cwd(), '../../packages/fonts/data/registry.json');
const registryRaw = JSON.parse(readFileSync(registryPath, 'utf-8'));

type SlimFont = {
  id: string;
  family: string;
  category: string;
  variable: boolean;
  weights: number[];
  subsets: number;
  source: string;
  tags: string[];
  contexts: string[];
  hasItalic: boolean;
  loadingImpact: string;
};

// Slim the font list — include system fonts too (filtered client-side)
const allFonts: SlimFont[] = (registryRaw.fonts as any[]).map((f: any) => ({
  id: f.id,
  family: f.family,
  category: f.category,
  variable: f.variable,
  weights: f.weights,
  subsets: f.subsets.length,
  source: f.source,
  tags: f.tags,
  contexts: f.contexts,
  hasItalic: f.hasItalic,
  loadingImpact: f.performance?.loadingImpact ?? 'minimal',
}));

// Category counts (google fonts only, matching default view)
const googleFonts = allFonts.filter(f => f.source !== 'system');
const categoryCounts: Record<string, number> = {
  'all': googleFonts.length,
  'sans-serif': googleFonts.filter(f => f.category === 'sans-serif').length,
  'serif': googleFonts.filter(f => f.category === 'serif').length,
  'display': googleFonts.filter(f => f.category === 'display').length,
  'handwriting': googleFonts.filter(f => f.category === 'handwriting').length,
  'monospace': googleFonts.filter(f => f.category === 'monospace').length,
};

const totalCount = registryRaw.count;
const fontDataJSON = JSON.stringify(allFonts);

const registryDescription = `Browse ${totalCount.toLocaleString()} fonts with metrics, pairings, fallback CSS, and context scores. Filter by category, style, or use case.`;

const jsonLdRegistry = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Fetchtype Font Registry',
  description: `Browse ${totalCount.toLocaleString()} fonts with metrics, pairings, and fallback CSS.`,
  url: 'https://fetchtype.com/registry',
  numberOfItems: totalCount,
};
---

<BaseLayout
  title="Font Registry"
  site="registry"
  currentPath="/registry"
  description={registryDescription}
>
  <SEOHead
    slot="head"
    title="Font Registry — Fetchtype"
    description={registryDescription}
    canonicalUrl="https://fetchtype.com/registry"
    ogType="website"
    jsonLd={jsonLdRegistry}
  />

  <div class="flex min-h-[calc(100vh-65px)]">

    <!-- Sidebar -->
    <aside id="sidebar" class="hidden md:flex flex-col w-[280px] flex-shrink-0 border-r border-thin sticky top-[65px] h-[calc(100vh-65px)] overflow-y-auto">
      <div class="p-6">

        <!-- Category Filters -->
        <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mb-3">Category</p>
        <nav id="category-nav" class="flex flex-col gap-px mb-8">
          <button
            data-category="all"
            class="category-btn active flex items-center justify-between px-3 py-2 text-sm font-medium tracking-wide transition-colors text-left w-full"
          >
            All Typefaces
            <span class="font-mono text-xs">{categoryCounts.all.toLocaleString()}</span>
          </button>
          <button
            data-category="sans-serif"
            class="category-btn flex items-center justify-between px-3 py-2 text-sm tracking-wide transition-colors text-left w-full text-ft-muted hover:text-ft-dark"
          >
            Sans Serif
            <span class="font-mono text-xs">{categoryCounts['sans-serif'].toLocaleString()}</span>
          </button>
          <button
            data-category="serif"
            class="category-btn flex items-center justify-between px-3 py-2 text-sm tracking-wide transition-colors text-left w-full text-ft-muted hover:text-ft-dark"
          >
            Serif
            <span class="font-mono text-xs">{categoryCounts.serif.toLocaleString()}</span>
          </button>
          <button
            data-category="display"
            class="category-btn flex items-center justify-between px-3 py-2 text-sm tracking-wide transition-colors text-left w-full text-ft-muted hover:text-ft-dark"
          >
            Display
            <span class="font-mono text-xs">{categoryCounts.display.toLocaleString()}</span>
          </button>
          <button
            data-category="handwriting"
            class="category-btn flex items-center justify-between px-3 py-2 text-sm tracking-wide transition-colors text-left w-full text-ft-muted hover:text-ft-dark"
          >
            Handwriting
            <span class="font-mono text-xs">{categoryCounts.handwriting.toLocaleString()}</span>
          </button>
          <button
            data-category="monospace"
            class="category-btn flex items-center justify-between px-3 py-2 text-sm tracking-wide transition-colors text-left w-full text-ft-muted hover:text-ft-dark"
          >
            Monospace
            <span class="font-mono text-xs">{categoryCounts.monospace.toLocaleString()}</span>
          </button>
        </nav>

        <!-- Context Filters -->
        <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mb-3">Context</p>
        <nav id="context-nav" class="flex flex-col gap-px mb-8">
          {['display', 'interface', 'reading', 'editorial', 'mono', 'data'].map(ctx => (
            <button
              data-context={ctx}
              class="context-btn flex items-center justify-between px-3 py-2 text-sm tracking-wide transition-colors text-left w-full text-ft-muted hover:text-ft-dark capitalize"
            >
              {ctx}
            </button>
          ))}
        </nav>

        <!-- Toggles -->
        <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mb-3">Options</p>
        <div class="flex flex-col gap-3">
          <label class="flex items-center gap-3 px-3 py-2 cursor-pointer group">
            <input
              type="checkbox"
              id="toggle-variable"
              class="w-4 h-4 border border-thin bg-ft-cream cursor-pointer"
            />
            <span class="text-sm text-ft-muted group-hover:text-ft-dark transition-colors tracking-wide">Variable only</span>
          </label>
          <label class="flex items-center gap-3 px-3 py-2 cursor-pointer group">
            <input
              type="checkbox"
              id="toggle-system"
              class="w-4 h-4 border border-thin bg-ft-cream cursor-pointer"
            />
            <span class="text-sm text-ft-muted group-hover:text-ft-dark transition-colors tracking-wide">Include system fonts</span>
          </label>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 min-w-0">

      <!-- Header bar -->
      <div class="border-b border-thin px-6 py-4 flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex-1">
          <h1 class="font-display text-3xl leading-tight">Font Registry</h1>
          <p id="result-count" class="text-ft-muted font-mono text-xs mt-1 tracking-wide">
            {categoryCounts.all.toLocaleString()} typefaces
          </p>
        </div>
        <div class="flex items-center gap-3">
          <input
            type="search"
            id="search-input"
            placeholder="Search fonts..."
            autocomplete="off"
            class="bg-ft-surface border border-thin px-4 py-2 text-sm font-mono w-64 focus:outline-none focus:border-ft-accent placeholder:text-ft-muted"
          />
          <!-- Mobile sidebar toggle -->
          <button
            id="mobile-filter-btn"
            class="md:hidden bg-ft-surface border border-thin px-3 py-2 text-xs font-mono uppercase tracking-wider"
          >
            Filters
          </button>
        </div>
      </div>

      <!-- Mobile sidebar drawer (hidden by default) -->
      <div id="mobile-sidebar" class="hidden md:hidden border-b border-thin bg-ft-surface">
        <div class="p-4">
          <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mb-2">Category</p>
          <div class="flex flex-wrap gap-2 mb-4">
            {['all', 'sans-serif', 'serif', 'display', 'handwriting', 'monospace'].map(cat => (
              <button
                data-category={cat}
                class="mobile-category-btn px-3 py-1 text-xs font-mono border border-thin bg-ft-cream transition-colors capitalize"
              >
                {cat === 'all' ? 'All' : cat}
              </button>
            ))}
          </div>
          <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mb-2">Context</p>
          <div class="flex flex-wrap gap-2 mb-4">
            {['display', 'interface', 'reading', 'editorial', 'mono', 'data'].map(ctx => (
              <button
                data-context={ctx}
                class="mobile-context-btn px-3 py-1 text-xs font-mono border border-thin bg-ft-cream transition-colors capitalize"
              >
                {ctx}
              </button>
            ))}
          </div>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="mobile-toggle-variable" />
              <span class="text-xs font-mono text-ft-muted">Variable only</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="mobile-toggle-system" />
              <span class="text-xs font-mono text-ft-muted">System fonts</span>
            </label>
          </div>
        </div>
      </div>

      <!-- Font grid (populated by JS via DOM methods) -->
      <div id="font-grid" class="divide-y divide-[var(--color-ft-border)]"></div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden px-6 py-20 text-center">
        <p class="font-display text-2xl text-ft-muted mb-2">No fonts found</p>
        <p class="text-ft-muted text-sm font-mono">Try a different search or clear your filters.</p>
        <button
          id="clear-filters"
          class="mt-6 px-4 py-2 bg-ft-surface border border-thin text-xs font-mono uppercase tracking-wider hover:bg-ft-dark hover:text-ft-cream transition-colors"
        >
          Clear Filters
        </button>
      </div>

      <!-- Load more -->
      <div id="load-more-container" class="border-t border-thin px-6 py-6 flex items-center justify-between">
        <p id="showing-count" class="text-ft-muted font-mono text-xs tracking-wide"></p>
        <button
          id="load-more-btn"
          class="hidden px-6 py-2 bg-ft-dark text-ft-cream text-xs font-mono uppercase tracking-wider hover:bg-ft-code-bg transition-colors"
        >
          Load more
        </button>
      </div>

    </div>
  </div>

  <!-- Embedded font data (build-time static JSON, no user input) -->
  <script id="font-data" type="application/json" set:html={fontDataJSON}></script>

  <script>
    // ─── Types ────────────────────────────────────────────────────────────────
    interface SlimFont {
      id: string;
      family: string;
      category: string;
      variable: boolean;
      weights: number[];
      subsets: number;
      source: string;
      tags: string[];
      contexts: string[];
      hasItalic: boolean;
      loadingImpact: string;
    }

    // ─── Data ─────────────────────────────────────────────────────────────────
    const allFonts: SlimFont[] = JSON.parse(
      document.getElementById('font-data')!.textContent!
    );

    // ─── State ────────────────────────────────────────────────────────────────
    const PAGE_SIZE = 50;
    let state = {
      query: '',
      category: 'all',
      context: '',
      variableOnly: false,
      includeSystem: false,
      page: 1,
    };

    // ─── Font lazy-loading via IntersectionObserver ───────────────────────────
    const loadedFonts = new Set<string>();
    const fontObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const family = el.dataset.family;
          if (!family || loadedFonts.has(family)) return;
          loadedFonts.add(family);
          fontObserver.unobserve(el);
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = `https://fonts.googleapis.com/css2?family=${encodeURIComponent(family).replace(/%20/g, '+')}:wght@400&display=swap`;
          document.head.appendChild(link);
        });
      },
      { rootMargin: '200px' }
    );

    // ─── Filter ───────────────────────────────────────────────────────────────
    function getFiltered(): SlimFont[] {
      const q = state.query.toLowerCase();
      return allFonts.filter(f => {
        if (!state.includeSystem && f.source === 'system') return false;
        if (state.category !== 'all' && f.category !== state.category) return false;
        if (state.context && !f.contexts.includes(state.context)) return false;
        if (state.variableOnly && !f.variable) return false;
        if (q && !f.family.toLowerCase().includes(q) && !f.tags.some(t => t.toLowerCase().includes(q))) return false;
        return true;
      });
    }

    // ─── DOM card builder (no innerHTML with data) ────────────────────────────
    const CATEGORY_ABBR: Record<string, string> = {
      'sans-serif': 'Sans',
      serif: 'Serif',
      display: 'Disp',
      handwriting: 'Hand',
      monospace: 'Mono',
    };

    const IMPACT_COLOR: Record<string, string> = {
      minimal: '#16a34a',
      moderate: '#ca8a04',
      heavy: '#dc2626',
    };

    function buildCard(font: SlimFont, index: number): HTMLElement {
      const article = document.createElement('article');
      article.className = 'font-card group flex items-stretch hover:bg-[#e8e8e4] transition-colors cursor-pointer';
      article.dataset.family = font.family;
      article.dataset.id = font.id;

      // Number column
      const numCol = document.createElement('div');
      numCol.className = 'hidden sm:flex items-start pt-5 px-6 w-24 flex-shrink-0';
      const numSpan = document.createElement('span');
      numSpan.className = 'font-mono text-xs text-ft-muted';
      numSpan.textContent = `#${String(index + 1).padStart(3, '0')}`;
      numCol.appendChild(numSpan);

      // Main column
      const mainCol = document.createElement('div');
      mainCol.className = 'flex-1 px-6 py-5 min-w-0';

      // Meta row
      const metaRow = document.createElement('div');
      metaRow.className = 'flex items-center gap-3 mb-2 flex-wrap';

      const catSpan = document.createElement('span');
      catSpan.className = 'font-mono text-[10px] text-ft-muted uppercase tracking-wider';
      catSpan.textContent = CATEGORY_ABBR[font.category] ?? font.category;
      metaRow.appendChild(catSpan);

      if (font.source === 'system') {
        const sysSpan = document.createElement('span');
        sysSpan.className = 'font-mono text-[10px] text-ft-muted uppercase tracking-wider';
        sysSpan.textContent = 'System';
        metaRow.appendChild(sysSpan);
      }

      if (font.variable) {
        const varBadge = document.createElement('span');
        varBadge.className = 'px-1.5 py-0.5 bg-ft-accent text-white font-mono text-[10px] uppercase tracking-wider';
        varBadge.textContent = 'Variable';
        metaRow.appendChild(varBadge);
      }

      const spacer = document.createElement('span');
      spacer.className = 'ml-auto font-mono text-[10px]';
      spacer.style.color = IMPACT_COLOR[font.loadingImpact] ?? 'inherit';
      spacer.textContent = font.loadingImpact;
      metaRow.appendChild(spacer);

      mainCol.appendChild(metaRow);

      // Font name preview — large, rendered in the actual font
      const preview = document.createElement('p');
      preview.className = 'font-preview text-4xl leading-tight truncate mb-3 tracking-tight';
      preview.style.fontFamily = `"${font.family}", sans-serif`;
      preview.textContent = font.family;
      mainCol.appendChild(preview);

      // Spec row
      const specRow = document.createElement('div');
      specRow.className = 'flex flex-wrap items-center gap-2';

      const weightSpan = document.createElement('span');
      weightSpan.className = 'font-mono text-xs text-ft-muted';
      weightSpan.textContent = `${font.weights.length} weight${font.weights.length !== 1 ? 's' : ''}`;
      specRow.appendChild(weightSpan);

      const dot1 = document.createElement('span');
      dot1.className = 'font-mono text-xs text-ft-muted';
      dot1.textContent = '·';
      specRow.appendChild(dot1);

      const subsetSpan = document.createElement('span');
      subsetSpan.className = 'font-mono text-xs text-ft-muted';
      subsetSpan.textContent = `${font.subsets} subset${font.subsets !== 1 ? 's' : ''}`;
      specRow.appendChild(subsetSpan);

      if (font.hasItalic) {
        const dot2 = document.createElement('span');
        dot2.className = 'font-mono text-xs text-ft-muted';
        dot2.textContent = '· Italic';
        specRow.appendChild(dot2);
      }

      // Context badges
      font.contexts.slice(0, 3).forEach(ctx => {
        const badge = document.createElement('span');
        badge.className = 'px-2 py-0.5 bg-ft-surface text-ft-muted font-mono text-[10px] uppercase tracking-wider';
        badge.textContent = ctx;
        specRow.appendChild(badge);
      });

      mainCol.appendChild(specRow);

      // Arrow column
      const arrowCol = document.createElement('div');
      arrowCol.className = 'hidden sm:flex items-center px-6 text-ft-muted group-hover:text-ft-dark transition-colors';
      arrowCol.setAttribute('aria-hidden', 'true');
      const svgNS = 'http://www.w3.org/2000/svg';
      const svg = document.createElementNS(svgNS, 'svg');
      svg.setAttribute('width', '16');
      svg.setAttribute('height', '16');
      svg.setAttribute('viewBox', '0 0 16 16');
      svg.setAttribute('fill', 'none');
      const path = document.createElementNS(svgNS, 'path');
      path.setAttribute('d', 'M3 8h10M9 4l4 4-4 4');
      path.setAttribute('stroke', 'currentColor');
      path.setAttribute('stroke-width', '1.5');
      path.setAttribute('stroke-linecap', 'square');
      svg.appendChild(path);
      arrowCol.appendChild(svg);

      article.appendChild(numCol);
      article.appendChild(mainCol);
      article.appendChild(arrowCol);

      return article;
    }

    // ─── Render ───────────────────────────────────────────────────────────────
    function render() {
      const grid = document.getElementById('font-grid')!;
      const emptyState = document.getElementById('empty-state')!;
      const loadMoreBtn = document.getElementById('load-more-btn')!;
      const loadMoreContainer = document.getElementById('load-more-container')!;
      const showingCount = document.getElementById('showing-count')!;
      const resultCount = document.getElementById('result-count')!;

      const filtered = getFiltered();
      const total = filtered.length;
      const showing = Math.min(state.page * PAGE_SIZE, total);
      const visible = filtered.slice(0, showing);

      resultCount.textContent = `${total.toLocaleString()} typeface${total !== 1 ? 's' : ''}`;

      if (total === 0) {
        // Clear grid safely
        while (grid.firstChild) grid.removeChild(grid.firstChild);
        emptyState.classList.remove('hidden');
        loadMoreContainer.classList.add('hidden');
        return;
      }

      emptyState.classList.add('hidden');
      loadMoreContainer.classList.remove('hidden');

      // Rebuild grid with DOM methods
      const fragment = document.createDocumentFragment();
      visible.forEach((font, i) => {
        const card = buildCard(font, i);
        fragment.appendChild(card);
      });

      // Clear and repopulate
      while (grid.firstChild) grid.removeChild(grid.firstChild);
      grid.appendChild(fragment);

      // Observe cards for lazy font loading
      grid.querySelectorAll<HTMLElement>('.font-card').forEach(card => {
        fontObserver.observe(card);
      });

      showingCount.textContent = `Showing ${showing.toLocaleString()} of ${total.toLocaleString()}`;
      loadMoreBtn.classList.toggle('hidden', showing >= total);
    }

    // ─── Active state helpers ─────────────────────────────────────────────────
    function updateSidebarActive() {
      document.querySelectorAll<HTMLElement>('.category-btn, .mobile-category-btn').forEach(btn => {
        const isActive = (btn.dataset.category ?? '') === state.category;
        btn.classList.toggle('bg-ft-surface', isActive);
        btn.classList.toggle('text-ft-dark', isActive);
        btn.classList.toggle('font-medium', isActive);
        btn.classList.toggle('text-ft-muted', !isActive);
        btn.classList.toggle('active', isActive);
      });

      document.querySelectorAll<HTMLElement>('.context-btn, .mobile-context-btn').forEach(btn => {
        const isActive = (btn.dataset.context ?? '') === state.context;
        btn.classList.toggle('bg-ft-surface', isActive);
        btn.classList.toggle('text-ft-dark', isActive);
        btn.classList.toggle('font-medium', isActive);
        btn.classList.toggle('text-ft-muted', !isActive);
      });
    }

    // ─── Event listeners ──────────────────────────────────────────────────────
    // Search (debounced)
    let searchTimer: ReturnType<typeof setTimeout>;
    document.getElementById('search-input')?.addEventListener('input', e => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        state.query = (e.target as HTMLInputElement).value.trim();
        state.page = 1;
        render();
      }, 200);
    });

    // Category buttons
    document.querySelectorAll<HTMLElement>('.category-btn, .mobile-category-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        state.category = btn.dataset.category ?? 'all';
        state.page = 1;
        updateSidebarActive();
        render();
      });
    });

    // Context buttons (toggle)
    document.querySelectorAll<HTMLElement>('.context-btn, .mobile-context-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const ctx = btn.dataset.context ?? '';
        state.context = state.context === ctx ? '' : ctx;
        state.page = 1;
        updateSidebarActive();
        render();
      });
    });

    // Checkbox: variable only
    function bindCheckbox(id: string, key: keyof typeof state) {
      document.getElementById(id)?.addEventListener('change', e => {
        (state as any)[key] = (e.target as HTMLInputElement).checked;
        // Sync the paired checkbox (desktop ↔ mobile)
        const pairedId = id.startsWith('mobile-') ? id.slice(7) : `mobile-${id}`;
        const paired = document.getElementById(pairedId) as HTMLInputElement | null;
        if (paired) paired.checked = (state as any)[key];
        state.page = 1;
        render();
      });
    }
    bindCheckbox('toggle-variable', 'variableOnly');
    bindCheckbox('toggle-system', 'includeSystem');
    bindCheckbox('mobile-toggle-variable', 'variableOnly');
    bindCheckbox('mobile-toggle-system', 'includeSystem');

    // Load more
    document.getElementById('load-more-btn')?.addEventListener('click', () => {
      state.page += 1;
      render();
    });

    // Clear filters
    document.getElementById('clear-filters')?.addEventListener('click', () => {
      state = { query: '', category: 'all', context: '', variableOnly: false, includeSystem: false, page: 1 };
      (document.getElementById('search-input') as HTMLInputElement).value = '';
      (document.getElementById('toggle-variable') as HTMLInputElement).checked = false;
      (document.getElementById('toggle-system') as HTMLInputElement).checked = false;
      (document.getElementById('mobile-toggle-variable') as HTMLInputElement | null)?.removeAttribute('checked');
      (document.getElementById('mobile-toggle-system') as HTMLInputElement | null)?.removeAttribute('checked');
      updateSidebarActive();
      render();
    });

    // Mobile filter drawer toggle
    document.getElementById('mobile-filter-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-sidebar')?.classList.toggle('hidden');
    });

    // Card click → navigate to font detail page
    document.getElementById('font-grid')?.addEventListener('click', e => {
      const card = (e.target as HTMLElement).closest<HTMLElement>('.font-card');
      if (card?.dataset.id) {
        window.location.href = `/${card.dataset.id}`;
      }
    });

    // ─── Boot ─────────────────────────────────────────────────────────────────
    updateSidebarActive();
    render();
  </script>

  <style>
    .category-btn.active {
      background-color: var(--color-ft-surface);
      color: var(--color-ft-dark);
      font-weight: 500;
    }

    aside {
      scrollbar-width: thin;
      scrollbar-color: var(--color-ft-border) transparent;
    }

    .font-preview {
      color: var(--color-ft-dark);
    }

    input[type="checkbox"] {
      accent-color: var(--color-ft-accent);
    }

    #mobile-sidebar {
      animation: slideDown 0.15s ease;
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-4px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</BaseLayout>
