---
import BaseLayout from '@fetchtype/ui/src/components/BaseLayout.astro';
import SEOHead from '@fetchtype/ui/src/components/SEOHead.astro';
import '../styles/global.css';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import type { FontEntry, PairingRecommendation } from '@fetchtype/types';

// ---------------------------------------------------------------------------
// Build-time data loading
// ---------------------------------------------------------------------------

const registryPath = resolve(process.cwd(), '../../packages/fonts/data/registry.json');
const registryRaw = JSON.parse(readFileSync(registryPath, 'utf-8'));
const allFonts: FontEntry[] = registryRaw.fonts;

// ---------------------------------------------------------------------------
// getStaticPaths — one page per font
// ---------------------------------------------------------------------------

export function getStaticPaths() {
  const regPath = resolve(process.cwd(), '../../packages/fonts/data/registry.json');
  const reg = JSON.parse(readFileSync(regPath, 'utf-8'));
  return (reg.fonts as FontEntry[]).map((font: FontEntry) => ({
    params: { fontId: font.id },
    props: { font },
  }));
}

// ---------------------------------------------------------------------------
// Props & pairing resolution (build-time)
// ---------------------------------------------------------------------------

const { font } = Astro.props as { font: FontEntry };

// Resolve pairings from the registry pairing data (no dynamic import needed)
// Use the embedded pairing.recommended data from the font entry itself
const rawPairings: PairingRecommendation[] = font.pairing?.recommended ?? [];

// Resolve each pairing to its full FontEntry for display
const pairingDetails = rawPairings
  .slice(0, 5)
  .map((rec) => {
    const paired = allFonts.find((f) => f.id === rec.fontId);
    return paired ? { font: paired, role: rec.role, confidence: rec.confidence, rationale: rec.rationale } : null;
  })
  .filter((p): p is { font: FontEntry; role: string; confidence: number; rationale: string } => p !== null);

// ---------------------------------------------------------------------------
// Derived display values
// ---------------------------------------------------------------------------

const hasMetrics = font.metrics != null;
const isGoogleFont = font.source === 'google';
const isSystemFont = font.source === 'system';

// Google Fonts CSS2 URL for loading all weights at build time
const googleFontsWeights = font.weights.sort((a, b) => a - b);
const weightSpec = googleFontsWeights.join(';');
const italicSpec = font.hasItalic
  ? `${googleFontsWeights.map((w) => `0,${w}`).join(';')};${googleFontsWeights.map((w) => `1,${w}`).join(';')}`
  : googleFontsWeights.join(';');
const familyParam = font.family.replace(/ /g, '+');
const googleFontsUrl = font.hasItalic
  ? `https://fonts.googleapis.com/css2?family=${familyParam}:ital,wght@${italicSpec}&display=swap`
  : `https://fonts.googleapis.com/css2?family=${familyParam}:wght@${weightSpec}&display=swap`;

// Category display
const CATEGORY_LABEL: Record<string, string> = {
  'sans-serif': 'Sans Serif',
  serif: 'Serif',
  display: 'Display',
  handwriting: 'Handwriting',
  monospace: 'Monospace',
};

// Loading impact badge color
const IMPACT_COLOR: Record<string, string> = {
  minimal: 'text-green-700 bg-green-50 border-green-200',
  moderate: 'text-yellow-700 bg-yellow-50 border-yellow-200',
  heavy: 'text-red-700 bg-red-50 border-red-200',
};

const impactClass = IMPACT_COLOR[font.performance.loadingImpact] ?? 'text-ft-muted bg-ft-surface border-thin';

// Context score display
const CONTEXT_LABELS: Record<string, string> = {
  display: 'Display',
  interface: 'Interface',
  reading: 'Reading',
  mono: 'Mono',
  editorial: 'Editorial',
  data: 'Data',
};

// Estimated payload in KB
const payloadKB = (font.performance.estimatedPayload / 1024).toFixed(1);

// Build deployment snippets
const fetchtypeCmd = `fetchtype resolve ${font.id} --css`;
const googleFontsLink = `<link rel="stylesheet" href="${googleFontsUrl}" />`;
const npmPackage = font.install?.npmPackage ?? `@fontsource/${font.id}`;
const npmCmd = `npm install ${npmPackage}`;

// Context scores (all 6 — map from contexts array + heuristic scoring)
// The registry stores contexts as an array; we derive approximate scores from
// whether the context is listed (1.0) or not (0.0) per font, using the
// pairing confidence and weight heuristics as a proxy. Since the registry
// uses a boolean membership model (contexts: string[]), we present presence
// as full score and absence as 0 for the bar chart.
const CONTEXT_KEYS = ['display', 'interface', 'reading', 'mono', 'editorial', 'data'] as const;

// For richer scoring, we use a heuristic based on category + context membership
function deriveContextScore(ctx: string, f: FontEntry): number {
  if (f.contexts.includes(ctx as any)) {
    // Primary context boost
    const isPrimary = f.category === ctx ||
      (ctx === 'mono' && f.category === 'monospace') ||
      (ctx === 'display' && f.category === 'display') ||
      (ctx === 'reading' && f.category === 'serif') ||
      (ctx === 'interface' && f.category === 'sans-serif');
    return isPrimary ? 0.95 : 0.75;
  }
  return 0;
}

const contextScores = CONTEXT_KEYS.map((key) => ({
  key,
  label: CONTEXT_LABELS[key] ?? key,
  score: deriveContextScore(key, font),
}));

// Page title/description
const pageTitle = font.family;
const pageDescription = `${font.family} — ${CATEGORY_LABEL[font.category] ?? font.category} typeface. ${font.weights.length} weights, ${font.subsets.length} subsets. ${font.variable ? 'Variable font.' : ''} Font metrics, context scores, pairing recommendations, and deployment snippets.`;

// Fontsource install string (for npm tab)
const fontsourceId = font.install?.fontsource ?? font.id;

// SEO
const canonicalUrl = `https://registry.fetchtype.com/${font.id}`;

// Platform rendering labels and icons
const PLATFORM_LABELS: Record<string, string> = {
  apple: 'Apple (Core Text)',
  windows: 'Windows (DirectWrite)',
  android: 'Android (FreeType)',
  linux: 'Linux (FreeType)',
  universal: 'Universal Fallback',
};
const PLATFORM_ICONS: Record<string, string> = {
  apple: '🍎',
  windows: '🪟',
  android: '🤖',
  linux: '🐧',
  universal: '🌐',
};

function getPlatformDrift(sizeAdjustStr: string): { drift: number; driftClass: string; driftLabel: string } {
  const sizeAdj = parseFloat(sizeAdjustStr);
  const drift = Math.abs(sizeAdj - 100);
  const driftClass = drift < 2
    ? 'text-green-700 bg-green-50 border-green-200'
    : drift < 5
      ? 'text-yellow-700 bg-yellow-50 border-yellow-200'
      : 'text-red-700 bg-red-50 border-red-200';
  const driftLabel = drift < 2 ? 'Excellent' : drift < 5 ? 'Good' : 'Notable shift';
  return { drift, driftClass, driftLabel };
}

// Generate a descriptive sentence based on font contexts
function contextSentence(f: FontEntry): string {
  const ctx = f.contexts;
  if (ctx.includes('reading')) return 'Ideal for long-form reading and editorial design.';
  if (ctx.includes('display')) return 'Best suited for headlines, titles, and large display settings.';
  if (ctx.includes('mono')) return 'Designed for code editors, terminals, and tabular data.';
  if (ctx.includes('interface')) return 'Optimized for UI components, dashboards, and application interfaces.';
  if (ctx.includes('editorial')) return 'A strong choice for editorial, magazine, and publishing layouts.';
  return 'A versatile typeface suitable for a range of design contexts.';
}

const seoDescription = `${font.family} is a ${CATEGORY_LABEL[font.category] ?? font.category} typeface with ${font.weights.length} weight${font.weights.length !== 1 ? 's' : ''}${font.variable ? ', variable font support' : ''}, available in ${font.subsets.length} character set${font.subsets.length !== 1 ? 's' : ''}. ${contextSentence(font)}`;

const jsonLdFont = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: font.family,
  applicationCategory: 'Font',
  applicationSubCategory: CATEGORY_LABEL[font.category] ?? font.category,
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description: seoDescription,
  url: canonicalUrl,
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Registry', item: 'https://registry.fetchtype.com' },
    { '@type': 'ListItem', position: 2, name: font.family, item: canonicalUrl },
  ],
};
---

<BaseLayout
  title={pageTitle}
  site="registry"
  currentPath={`/${font.id}`}
  description={pageDescription}
>
  <!-- SEO head tags -->
  <SEOHead
    slot="head"
    title={`${font.family} — Fetchtype`}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
    ogType="website"
    jsonLd={[jsonLdFont, jsonLdBreadcrumb]}
  />

  <!-- Load font at page load (skip for system fonts) -->
  {!isSystemFont && (
    <link rel="stylesheet" href={googleFontsUrl} slot="head" />
  )}

  <!-- ── Main page shell ───────────────────────────────────────────────── -->
  <div class="max-w-[1400px] mx-auto">

    <!-- ── Breadcrumb ────────────────────────────────────────────────────── -->
    <nav class="border-b border-thin px-6 py-3 flex items-center gap-2 font-mono text-xs text-ft-muted">
      <a href="/" class="hover:text-ft-dark transition-colors">Fetchtype</a>
      <span aria-hidden="true">/</span>
      <a href="/" class="hover:text-ft-dark transition-colors">Registry</a>
      <span aria-hidden="true">/</span>
      <span class="text-ft-dark">{font.family}</span>
    </nav>

    <!-- ── Top Section ───────────────────────────────────────────────────── -->
    <section class="px-6 pt-10 pb-8 border-b border-thin">

      <!-- Font name — massive, rendered in the actual font -->
      <h1
        class="text-7xl md:text-8xl font-bold leading-none tracking-tight mb-6 break-words"
        style={`font-family: "${font.family}", ${font.category === 'monospace' ? 'monospace' : font.category === 'serif' ? 'serif' : font.category === 'handwriting' ? 'cursive' : 'sans-serif'};`}
      >
        {font.family}
      </h1>

      <!-- Meta line -->
      <p class="font-mono text-sm text-ft-muted mb-5 flex flex-wrap items-center gap-x-4 gap-y-1">
        <span class="uppercase tracking-wider">{CATEGORY_LABEL[font.category] ?? font.category}</span>
        {font.source !== 'system' && (
          <>
            <span aria-hidden="true" class="text-ft-border">|</span>
            <span class="capitalize">{font.source === 'google' ? 'Google Fonts' : font.source === 'fontsource' ? 'Fontsource' : font.source}</span>
          </>
        )}
        {font.formats.length > 0 && (
          <>
            <span aria-hidden="true" class="text-ft-border">|</span>
            <span>{font.formats.map(f => f.toUpperCase()).join(' · ')}</span>
          </>
        )}
        {font.version && (
          <>
            <span aria-hidden="true" class="text-ft-border">|</span>
            <span>v{font.version}</span>
          </>
        )}
      </p>

      <!-- Badges row -->
      <div class="flex flex-wrap items-center gap-2">
        <!-- Category badge -->
        <span class="px-2 py-1 border border-thin bg-ft-surface font-mono text-xs uppercase tracking-wider text-ft-muted">
          {CATEGORY_LABEL[font.category] ?? font.category}
        </span>

        <!-- Variable badge -->
        {font.variable && (
          <span class="px-2 py-1 bg-ft-accent text-white font-mono text-xs uppercase tracking-wider">
            Variable
          </span>
        )}

        <!-- Italic badge -->
        {font.hasItalic && (
          <span class="px-2 py-1 border border-thin bg-ft-surface font-mono text-xs uppercase tracking-wider text-ft-muted">
            Italic
          </span>
        )}

        <!-- System font badge -->
        {isSystemFont && (
          <span class="px-2 py-1 border border-thin bg-ft-surface font-mono text-xs uppercase tracking-wider text-ft-muted">
            System
          </span>
        )}

        <!-- Loading impact badge -->
        <span class={`px-2 py-1 border font-mono text-xs uppercase tracking-wider ${impactClass}`}>
          {font.performance.loadingImpact}
        </span>

        <!-- License badge -->
        {font.license?.type && (
          <a
            href={font.license.url ?? '#'}
            target="_blank"
            rel="noopener noreferrer"
            class="px-2 py-1 border border-thin bg-ft-surface font-mono text-xs uppercase tracking-wider text-ft-muted hover:text-ft-dark hover:border-ft-dark transition-colors"
          >
            {font.license.type}
          </a>
        )}

        <!-- Payload estimate -->
        <span class="ml-auto font-mono text-xs text-ft-muted">
          ~{payloadKB} KB
        </span>
      </div>
    </section>

    <!-- ── Type Tester ────────────────────────────────────────────────────── -->
    <section class="border-b border-thin">
      <div class="px-6 py-4 border-b border-thin flex items-center justify-between">
        <h2 class="font-display text-lg">Type Tester</h2>
        <span class="font-mono text-xs text-ft-muted uppercase tracking-wider">Interactive</span>
      </div>

      <div class="flex flex-col lg:flex-row">
        <!-- Editable text area -->
        <div class="flex-1 border-b lg:border-b-0 lg:border-r border-thin">
          <div
            id="type-tester"
            contenteditable="true"
            spellcheck="false"
            data-placeholder="The quick brown fox jumps over the lazy dog"
            class="min-h-[240px] p-8 focus:outline-none text-ft-dark w-full leading-tight"
            style={`font-family: "${font.family}", ${font.category === 'monospace' ? 'monospace' : font.category === 'serif' ? 'serif' : 'sans-serif'}; font-size: 48px; font-weight: 400; line-height: 1.2;`}
            aria-label="Type tester — edit text to preview font"
            role="textbox"
            aria-multiline="true"
          >The quick brown fox jumps over the lazy dog</div>
        </div>

        <!-- Controls panel -->
        <div class="lg:w-72 flex-shrink-0 bg-ft-surface">
          <div class="p-6 flex flex-col gap-6">

            <!-- Size -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <label for="size-slider" class="font-mono text-xs text-ft-muted uppercase tracking-wider">Size</label>
                <span id="size-value" class="font-mono text-xs text-ft-dark">48px</span>
              </div>
              <input
                id="size-slider"
                type="range"
                min="12"
                max="120"
                value="48"
                step="1"
                class="w-full accent-[var(--color-ft-accent)] h-px bg-ft-border appearance-none cursor-pointer"
              />
              <div class="flex justify-between mt-1">
                <span class="font-mono text-[10px] text-ft-muted">12</span>
                <span class="font-mono text-[10px] text-ft-muted">120</span>
              </div>
            </div>

            <!-- Line Height -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <label for="lh-slider" class="font-mono text-xs text-ft-muted uppercase tracking-wider">Line Height</label>
                <span id="lh-value" class="font-mono text-xs text-ft-dark">1.2</span>
              </div>
              <input
                id="lh-slider"
                type="range"
                min="0.8"
                max="2.0"
                value="1.2"
                step="0.05"
                class="w-full accent-[var(--color-ft-accent)] h-px bg-ft-border appearance-none cursor-pointer"
              />
              <div class="flex justify-between mt-1">
                <span class="font-mono text-[10px] text-ft-muted">0.8</span>
                <span class="font-mono text-[10px] text-ft-muted">2.0</span>
              </div>
            </div>

            <!-- Weight selector -->
            <div>
              <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mb-2">Weight</p>
              <div class="flex flex-wrap gap-1.5">
                {font.weights.sort((a, b) => a - b).map((w) => (
                  <button
                    class="weight-btn px-2 py-1 font-mono text-xs border border-thin bg-ft-cream hover:bg-ft-dark hover:text-ft-cream transition-colors"
                    data-weight={w}
                    aria-label={`Weight ${w}`}
                  >
                    {w}
                  </button>
                ))}
              </div>
            </div>

            <!-- Italic toggle (only if italic available) -->
            {font.hasItalic && (
              <div>
                <p class="font-mono text-xs text-ft-muted uppercase tracking-wider mb-2">Style</p>
                <div class="flex gap-1.5">
                  <button
                    id="style-normal"
                    class="style-btn px-3 py-1.5 font-mono text-xs border border-thin bg-ft-dark text-ft-cream transition-colors"
                    data-style="normal"
                  >
                    Regular
                  </button>
                  <button
                    id="style-italic"
                    class="style-btn px-3 py-1.5 font-mono text-xs border border-thin bg-ft-cream hover:bg-ft-dark hover:text-ft-cream transition-colors"
                    data-style="italic"
                  >
                    Italic
                  </button>
                </div>
              </div>
            )}

            <!-- Reset button -->
            <button
              id="reset-tester"
              class="w-full px-3 py-2 font-mono text-xs border border-thin bg-ft-cream text-ft-muted uppercase tracking-wider hover:bg-ft-dark hover:text-ft-cream transition-colors"
            >
              Reset
            </button>

          </div>
        </div>
      </div>
    </section>

    <!-- ── Two-column lower layout ────────────────────────────────────────── -->
    <div class="flex flex-col lg:flex-row">

      <!-- Left column: metrics + context scores -->
      <div class="flex-1 min-w-0 border-b lg:border-b-0 lg:border-r border-thin divide-y divide-[var(--color-ft-border)]">

        <!-- Metrics Panel -->
        {hasMetrics && (
          <section class="px-6 py-8">
            <h2 class="font-display text-xl mb-6">Font Metrics</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-px bg-ft-border">
              <div class="bg-ft-cream p-4">
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-1">Units per Em</p>
                <p class="font-mono text-lg text-ft-dark">{font.metrics.unitsPerEm}</p>
              </div>
              <div class="bg-ft-cream p-4">
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-1">Ascent</p>
                <p class="font-mono text-lg text-ft-dark">{font.metrics.ascent}</p>
              </div>
              <div class="bg-ft-cream p-4">
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-1">Descent</p>
                <p class="font-mono text-lg text-ft-dark">{font.metrics.descent}</p>
              </div>
              <div class="bg-ft-cream p-4">
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-1">Line Gap</p>
                <p class="font-mono text-lg text-ft-dark">{font.metrics.lineGap}</p>
              </div>
              {font.metrics.xHeight != null && (
                <div class="bg-ft-cream p-4">
                  <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-1">x-Height</p>
                  <p class="font-mono text-lg text-ft-dark">{font.metrics.xHeight}</p>
                </div>
              )}
              {font.metrics.capHeight != null && (
                <div class="bg-ft-cream p-4">
                  <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-1">Cap Height</p>
                  <p class="font-mono text-lg text-ft-dark">{font.metrics.capHeight}</p>
                </div>
              )}
            </div>
          </section>
        )}

        <!-- Context Scores -->
        <section class="px-6 py-8">
          <h2 class="font-display text-xl mb-6">Context Scores</h2>
          <div class="flex flex-col gap-4">
            {contextScores.map(({ key, label, score }) => (
              <div>
                <div class="flex items-center justify-between mb-1.5">
                  <span class="font-mono text-xs text-ft-muted uppercase tracking-wider">{label}</span>
                  <span class="font-mono text-xs text-ft-dark">{score > 0 ? Math.round(score * 100) + '%' : '—'}</span>
                </div>
                <div class="h-px bg-ft-border relative" style="height: 6px;">
                  <div
                    class="h-full bg-ft-accent transition-all duration-300"
                    style={`width: ${Math.round(score * 100)}%; background-color: var(--color-ft-accent);`}
                    role="meter"
                    aria-label={`${label} context score: ${Math.round(score * 100)}%`}
                    aria-valuenow={Math.round(score * 100)}
                    aria-valuemin={0}
                    aria-valuemax={100}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Platform Rendering -->
        {font.fallback?.targets?.length > 0 && (
          <section class="px-6 py-8">
            <h2 class="font-display text-xl mb-6">Platform Rendering</h2>
            <p class="font-body text-xs text-ft-muted mb-5 leading-relaxed">
              How this font renders across operating systems. Each platform uses a different text rendering engine
              with its own fallback font and metric adjustments.
            </p>
            <div class="flex flex-col gap-px bg-ft-border">
              {font.fallback.targets.map((t: any) => {
                const { drift, driftClass, driftLabel } = getPlatformDrift(t.overrides.sizeAdjust);
                return (
                  <div class="bg-ft-cream px-4 py-3">
                    <div class="flex items-center justify-between mb-1">
                      <div class="flex items-center gap-2">
                        <span class="text-sm">{PLATFORM_ICONS[t.target] ?? '💻'}</span>
                        <span class="font-mono text-xs text-ft-dark font-medium">
                          {PLATFORM_LABELS[t.target] ?? t.target}
                        </span>
                      </div>
                      <span class={`font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 border ${driftClass}`}>
                        {driftLabel}
                      </span>
                    </div>
                    <div class="flex items-center gap-4 font-mono text-[10px] text-ft-muted">
                      <span>Fallback: <span class="text-ft-dark">{t.fallbackFont}</span></span>
                      <span>Size adjust: <span class="text-ft-dark">{t.overrides.sizeAdjust}</span></span>
                    </div>
                  </div>
                );
              })}
            </div>
            {font.fallback.requiresPlatformSplit && (
              <p class="font-mono text-[10px] text-yellow-700 bg-yellow-50 border border-yellow-200 px-3 py-2 mt-3">
                This font requires platform-specific fallback splits for optimal rendering.
              </p>
            )}
          </section>
        )}

        <!-- Variable Axes (if variable) -->
        {font.variable && font.axes.length > 0 && (
          <section class="px-6 py-8">
            <h2 class="font-display text-xl mb-6">Variable Axes</h2>
            <div class="flex flex-col gap-px bg-ft-border">
              {font.axes.map((axis) => (
                <div class="bg-ft-cream px-4 py-3 flex items-center gap-6">
                  <span class="font-mono text-sm text-ft-accent uppercase w-12 flex-shrink-0">{axis.tag}</span>
                  <span class="font-mono text-xs text-ft-muted flex-1 truncate">{axis.name}</span>
                  <span class="font-mono text-xs text-ft-muted">
                    {axis.min} – {axis.max}
                    <span class="text-ft-dark ml-1">(default: {axis.default})</span>
                  </span>
                </div>
              ))}
            </div>
          </section>
        )}

      </div>

      <!-- Right column: pairings + deployment -->
      <div class="lg:w-[420px] flex-shrink-0 divide-y divide-[var(--color-ft-border)]">

        <!-- Pairings Section -->
        <section class="px-6 py-8">
          <h2 class="font-display text-xl mb-6">Pairings</h2>
          {pairingDetails.length === 0 ? (
            <p class="font-mono text-xs text-ft-muted">No pairing data available for this font.</p>
          ) : (
            <div class="flex flex-col gap-4">
              {pairingDetails.map(({ font: paired, role, confidence, rationale }) => (
                <a
                  href={`/${paired.id}`}
                  class="pairing-card group block border border-thin bg-ft-cream hover:bg-ft-surface transition-colors p-4"
                  data-family={paired.family}
                  data-source={paired.source}
                >
                  <!-- Pairing font name rendered in the paired font -->
                  <p
                    class="text-2xl leading-tight mb-2 text-ft-dark group-hover:text-ft-accent transition-colors"
                    style={`font-family: "${paired.family}", ${paired.category === 'monospace' ? 'monospace' : paired.category === 'serif' ? 'serif' : 'sans-serif'};`}
                  >
                    {paired.family}
                  </p>
                  <div class="flex items-center gap-3 mb-2">
                    <span class="font-mono text-[10px] text-ft-muted uppercase tracking-wider px-1.5 py-0.5 border border-thin bg-ft-surface">
                      {role}
                    </span>
                    <span class="font-mono text-[10px] text-ft-muted uppercase tracking-wider px-1.5 py-0.5 border border-thin bg-ft-surface">
                      {CATEGORY_LABEL[paired.category] ?? paired.category}
                    </span>
                    <span class="font-mono text-[10px] text-ft-muted ml-auto">
                      {Math.round(confidence * 100)}% match
                    </span>
                  </div>
                  <p class="font-mono text-[11px] text-ft-muted leading-relaxed">{rationale}</p>
                </a>
              ))}
            </div>
          )}
        </section>

        <!-- Deployment Panel -->
        <section class="px-6 py-8">
          <h2 class="font-display text-xl mb-6">Use This Font</h2>

          <!-- Tab buttons -->
          <div class="flex gap-px bg-ft-border mb-0 border border-thin border-b-0">
            <button
              class="deploy-tab active flex-1 px-4 py-2.5 font-mono text-xs uppercase tracking-wider bg-ft-dark text-ft-cream transition-colors"
              data-tab="fetchtype"
            >
              fetchtype
            </button>
            {!isSystemFont && (
              <button
                class="deploy-tab flex-1 px-4 py-2.5 font-mono text-xs uppercase tracking-wider bg-ft-surface text-ft-muted hover:text-ft-dark transition-colors"
                data-tab="google"
              >
                Google
              </button>
            )}
            {!isSystemFont && (
              <button
                class="deploy-tab flex-1 px-4 py-2.5 font-mono text-xs uppercase tracking-wider bg-ft-surface text-ft-muted hover:text-ft-dark transition-colors"
                data-tab="npm"
              >
                npm
              </button>
            )}
          </div>

          <!-- Tab content panels -->
          <div class="bg-ft-code-bg text-white border border-thin relative">

            <!-- fetchtype tab -->
            <div id="tab-fetchtype" class="deploy-panel block">
              <div class="px-4 pt-4 pb-1">
                <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-3">CLI / MCP</p>
                <pre class="font-mono text-sm text-white overflow-x-auto pb-4"><code>{fetchtypeCmd}</code></pre>
              </div>
              <div class="border-t border-white/10 px-4 py-2 flex items-center justify-between">
                <span class="font-mono text-[10px] text-ft-muted">Generates CSS with fallback stack</span>
                <button
                  class="copy-btn font-mono text-[10px] text-ft-muted hover:text-white transition-colors uppercase tracking-wider"
                  data-copy={fetchtypeCmd}
                  aria-label="Copy command"
                >
                  Copy
                </button>
              </div>
            </div>

            <!-- Google Fonts tab -->
            {!isSystemFont && (
              <div id="tab-google" class="deploy-panel hidden">
                <div class="px-4 pt-4 pb-1">
                  <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-3">HTML &lt;link&gt; tag</p>
                  <pre class="font-mono text-sm text-white overflow-x-auto pb-4 whitespace-pre-wrap break-all"><code>{googleFontsLink}</code></pre>
                </div>
                <div class="border-t border-white/10 px-4 py-2 flex items-center justify-between">
                  <span class="font-mono text-[10px] text-ft-muted">Add to &lt;head&gt;</span>
                  <button
                    class="copy-btn font-mono text-[10px] text-ft-muted hover:text-white transition-colors uppercase tracking-wider"
                    data-copy={googleFontsLink}
                    aria-label="Copy link tag"
                  >
                    Copy
                  </button>
                </div>
              </div>
            )}

            <!-- npm tab -->
            {!isSystemFont && (
              <div id="tab-npm" class="deploy-panel hidden">
                <div class="px-4 pt-4 pb-1">
                  <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-3">Fontsource package</p>
                  <pre class="font-mono text-sm text-white overflow-x-auto pb-4"><code>{npmCmd}</code></pre>
                </div>
                <div class="border-t border-white/10 px-4 py-2 flex items-center justify-between">
                  <span class="font-mono text-[10px] text-ft-muted">Self-hosted, no CDN dependency</span>
                  <button
                    class="copy-btn font-mono text-[10px] text-ft-muted hover:text-white transition-colors uppercase tracking-wider"
                    data-copy={npmCmd}
                    aria-label="Copy npm command"
                  >
                    Copy
                  </button>
                </div>
              </div>
            )}

          </div>
        </section>

      </div>
    </div>

    <!-- ── Font Details Table ─────────────────────────────────────────────── -->
    <section class="border-t border-thin px-6 py-8">
      <h2 class="font-display text-xl mb-6">Technical Details</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-ft-border">

        <div class="bg-ft-cream p-5">
          <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Weights</p>
          <p class="font-mono text-sm text-ft-dark leading-relaxed">
            {font.weights.sort((a, b) => a - b).join(', ')}
          </p>
        </div>

        <div class="bg-ft-cream p-5">
          <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Subsets</p>
          <p class="font-mono text-sm text-ft-dark leading-relaxed break-words">
            {font.subsets.join(', ')}
          </p>
        </div>

        <div class="bg-ft-cream p-5">
          <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Formats</p>
          <p class="font-mono text-sm text-ft-dark leading-relaxed">
            {font.formats.map(f => f.toUpperCase()).join(', ')}
          </p>
        </div>

        <div class="bg-ft-cream p-5">
          <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Source</p>
          <p class="font-mono text-sm text-ft-dark capitalize">{font.source}</p>
        </div>

        <div class="bg-ft-cream p-5">
          <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Variable</p>
          <p class="font-mono text-sm text-ft-dark">{font.variable ? 'Yes' : 'No'}</p>
        </div>

        <div class="bg-ft-cream p-5">
          <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Italic</p>
          <p class="font-mono text-sm text-ft-dark">{font.hasItalic ? 'Yes' : 'No'}</p>
        </div>

        {font.tags.length > 0 && (
          <div class="bg-ft-cream p-5 sm:col-span-2">
            <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Tags</p>
            <div class="flex flex-wrap gap-1.5">
              {font.tags.map((tag) => (
                <span class="font-mono text-[10px] text-ft-muted px-2 py-1 border border-thin bg-ft-surface uppercase tracking-wider">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}

        {font.license && (
          <div class="bg-ft-cream p-5">
            <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">License</p>
            <div class="flex flex-col gap-1">
              <span class="font-mono text-sm text-ft-dark">{font.license.type}</span>
              <span class="font-mono text-[10px] text-ft-muted">
                Commercial: {font.license.commercial ? 'Yes' : 'No'} ·
                Self-hostable: {font.license.selfHostable ? 'Yes' : 'No'}
              </span>
              {font.license.url && (
                <a
                  href={font.license.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono text-[10px] text-ft-accent hover:underline"
                >
                  View license
                </a>
              )}
            </div>
          </div>
        )}

        {font.variable && font.axes.length > 0 && (
          <div class="bg-ft-cream p-5 sm:col-span-2">
            <p class="font-mono text-[10px] text-ft-muted uppercase tracking-wider mb-2">Variable Axes</p>
            <p class="font-mono text-sm text-ft-dark">
              {font.axes.map(a => `${a.tag} (${a.min}–${a.max})`).join(' · ')}
            </p>
          </div>
        )}

      </div>
    </section>

    <!-- ── Footer nav ─────────────────────────────────────────────────────── -->
    <div class="border-t border-thin px-6 py-6 flex items-center justify-between">
      <a
        href="/"
        class="font-mono text-xs text-ft-muted hover:text-ft-dark transition-colors uppercase tracking-wider flex items-center gap-2"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M11 7H3M6 3l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
        Back to Registry
      </a>
      <span class="font-mono text-xs text-ft-muted">
        {font.id}
      </span>
    </div>

  </div>

  <!-- ── Client-side interactivity ──────────────────────────────────────── -->
  <script>
    // ─── Type Tester ──────────────────────────────────────────────────────────
    const tester = document.getElementById('type-tester') as HTMLElement | null;
    const sizeSlider = document.getElementById('size-slider') as HTMLInputElement | null;
    const sizeValue = document.getElementById('size-value');
    const lhSlider = document.getElementById('lh-slider') as HTMLInputElement | null;
    const lhValue = document.getElementById('lh-value');
    const resetBtn = document.getElementById('reset-tester');

    const DEFAULT_SIZE = 48;
    const DEFAULT_LH = 1.2;
    const DEFAULT_WEIGHT = 400;
    const DEFAULT_TEXT = 'The quick brown fox jumps over the lazy dog';

    let currentWeight = DEFAULT_WEIGHT;
    let currentStyle = 'normal';

    // Apply current weight + style
    function applyWeight(w: number) {
      currentWeight = w;
      if (tester) tester.style.fontWeight = String(w);
      // Update active state on weight buttons
      document.querySelectorAll<HTMLElement>('.weight-btn').forEach(btn => {
        const isActive = Number(btn.dataset.weight) === w;
        btn.classList.toggle('bg-ft-dark', isActive);
        btn.classList.toggle('text-ft-cream', isActive);
        btn.classList.toggle('bg-ft-cream', !isActive);
        btn.classList.toggle('text-ft-muted', !isActive);
      });
    }

    function applyStyle(s: string) {
      currentStyle = s;
      if (tester) tester.style.fontStyle = s;
      document.querySelectorAll<HTMLElement>('.style-btn').forEach(btn => {
        const isActive = btn.dataset.style === s;
        btn.classList.toggle('bg-ft-dark', isActive);
        btn.classList.toggle('text-ft-cream', isActive);
        btn.classList.toggle('bg-ft-cream', !isActive);
        btn.classList.toggle('text-ft-muted', !isActive);
      });
    }

    // Size slider
    sizeSlider?.addEventListener('input', () => {
      const v = sizeSlider.value;
      if (tester) tester.style.fontSize = `${v}px`;
      if (sizeValue) sizeValue.textContent = `${v}px`;
    });

    // Line height slider
    lhSlider?.addEventListener('input', () => {
      const v = parseFloat(lhSlider.value).toFixed(2);
      if (tester) tester.style.lineHeight = v;
      if (lhValue) lhValue.textContent = v;
    });

    // Weight buttons
    document.querySelectorAll<HTMLElement>('.weight-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        applyWeight(Number(btn.dataset.weight));
      });
    });

    // Style buttons
    document.querySelectorAll<HTMLElement>('.style-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        applyStyle(btn.dataset.style ?? 'normal');
      });
    });

    // Reset
    resetBtn?.addEventListener('click', () => {
      if (tester) {
        tester.textContent = DEFAULT_TEXT;
        tester.style.fontSize = `${DEFAULT_SIZE}px`;
        tester.style.lineHeight = String(DEFAULT_LH);
        tester.style.fontWeight = String(DEFAULT_WEIGHT);
        tester.style.fontStyle = 'normal';
      }
      if (sizeSlider) sizeSlider.value = String(DEFAULT_SIZE);
      if (sizeValue) sizeValue.textContent = `${DEFAULT_SIZE}px`;
      if (lhSlider) lhSlider.value = String(DEFAULT_LH);
      if (lhValue) lhValue.textContent = String(DEFAULT_LH);
      applyWeight(DEFAULT_WEIGHT);
      applyStyle('normal');
    });

    // Placeholder behavior for contenteditable
    if (tester) {
      tester.addEventListener('focus', () => {
        if (tester.textContent === DEFAULT_TEXT) {
          // keep text — user can select and replace
        }
      });
    }

    // Set initial weight button active state
    applyWeight(DEFAULT_WEIGHT);

    // ─── Deployment Tabs ──────────────────────────────────────────────────────
    const deployTabs = document.querySelectorAll<HTMLElement>('.deploy-tab');
    const deployPanels = document.querySelectorAll<HTMLElement>('.deploy-panel');

    deployTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;

        // Update tab styles
        deployTabs.forEach(t => {
          const isActive = t.dataset.tab === target;
          t.classList.toggle('bg-ft-dark', isActive);
          t.classList.toggle('text-ft-cream', isActive);
          t.classList.toggle('bg-ft-surface', !isActive);
          t.classList.toggle('text-ft-muted', !isActive);
          t.classList.remove('active');
          if (isActive) t.classList.add('active');
        });

        // Show/hide panels
        deployPanels.forEach(panel => {
          panel.classList.toggle('hidden', !panel.id.endsWith(`-${target}`));
          panel.classList.toggle('block', panel.id.endsWith(`-${target}`));
        });
      });
    });

    // ─── Copy to Clipboard ────────────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const text = btn.dataset.copy ?? '';
        try {
          await navigator.clipboard.writeText(text);
          const orig = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = orig; }, 1500);
        } catch {
          // Fallback for older browsers
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          const orig = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = orig; }, 1500);
        }
      });
    });

    // ─── Lazy-load pairing fonts ──────────────────────────────────────────────
    const loadedPairingFonts = new Set<string>();

    const pairingObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const family = el.dataset.family;
          const source = el.dataset.source;
          if (!family || loadedPairingFonts.has(family)) return;
          if (source === 'system') return; // Skip system fonts
          loadedPairingFonts.add(family);
          pairingObserver.unobserve(el);
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          const fp = family.replace(/ /g, '+');
          link.href = `https://fonts.googleapis.com/css2?family=${fp}:wght@400;700&display=swap`;
          document.head.appendChild(link);
        });
      },
      { rootMargin: '100px' }
    );

    document.querySelectorAll<HTMLElement>('.pairing-card').forEach(card => {
      pairingObserver.observe(card);
    });
  </script>

  <style>
    /* Type tester: empty state styling */
    #type-tester:empty::before {
      content: attr(data-placeholder);
      color: var(--color-ft-muted);
      pointer-events: none;
    }

    /* Range input styling */
    input[type="range"] {
      -webkit-appearance: none;
      appearance: none;
      height: 1px;
      background: var(--color-ft-border);
      cursor: pointer;
    }

    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 12px;
      height: 12px;
      background: var(--color-ft-dark);
      cursor: pointer;
      border-radius: 0;
    }

    input[type="range"]::-moz-range-thumb {
      width: 12px;
      height: 12px;
      background: var(--color-ft-dark);
      cursor: pointer;
      border-radius: 0;
      border: none;
    }

    /* Smooth font rendering for type tester */
    #type-tester {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      word-break: break-word;
      caret-color: var(--color-ft-accent);
    }

    /* Context score bars */
    [role="meter"] {
      display: block;
      min-width: 2px;
    }

    /* Deploy tab panel transitions */
    .deploy-panel {
      animation: fadeIn 0.15s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* Pairing card hover — font name color transition */
    .pairing-card p {
      transition: color 0.15s ease;
    }
  </style>

</BaseLayout>
