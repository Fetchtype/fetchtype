---
interface Props {
  code: string;
  lang?: string;
  title?: string;
}

const { code, lang = 'bash', title } = Astro.props;
---

<div class="border border-thin overflow-hidden">
  {title && (
    <div class="bg-ft-surface px-4 py-2 border-b border-thin">
      <span class="text-xs font-mono text-ft-muted uppercase tracking-wider">{title}</span>
    </div>
  )}
  <pre class="bg-ft-code-bg text-white p-4 overflow-x-auto text-sm leading-relaxed"><code class={`language-${lang}`}>{code}</code></pre>
</div>
