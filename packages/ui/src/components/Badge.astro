---
interface Props {
  variant?: 'default' | 'accent' | 'muted';
  label: string;
}

const { variant = 'default', label } = Astro.props;

const classes = {
  default: 'bg-ft-surface text-ft-dark border border-thin',
  accent: 'bg-ft-accent text-white',
  muted: 'text-ft-muted border border-thin',
};
---

<span class:list={['inline-flex items-center px-2 py-0.5 text-xs font-mono uppercase tracking-wider', classes[variant]]}>
  {label}
</span>
