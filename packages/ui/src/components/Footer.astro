---
const year = new Date().getFullYear();
---

<footer class="border-t border-thin mt-auto">
  <div class="max-w-[1400px] mx-auto px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-6">
      <span class="font-display text-lg text-ft-dark">Fetchtype</span>
      <span class="text-ft-muted text-xs font-mono">v0.1</span>
    </div>
    <div class="flex items-center gap-6 text-xs font-mono text-ft-muted">
      <a href="https://fetchtype.com" class="hover:text-ft-dark transition-colors">fetchtype.com</a>
      <a href="https://fetchtype.dev" class="hover:text-ft-dark transition-colors">fetchtype.dev</a>
      <a href="https://github.com/Tim-ReJet/fetchtype" class="hover:text-ft-dark transition-colors" target="_blank" rel="noopener">GitHub</a>
      <a href="https://www.npmjs.com/package/fetchtype" class="hover:text-ft-dark transition-colors" target="_blank" rel="noopener">npm</a>
    </div>
    <p class="text-ft-muted text-xs font-mono">© {year} Fetchtype</p>
  </div>
</footer>
