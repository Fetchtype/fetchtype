{
  "name": "fetchtype-vscode",
  "displayName": "fetchtype",
  "description": "Typography validation for design tokens",
  "version": "0.1.0",
  "publisher": "fetchtype",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters"],
  "activationEvents": ["onLanguage:json"],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [{
      "id": "json",
      "filenames": ["*.tokens.json"]
    }]
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --out-dir dist --external vscode",
    "typecheck": "echo 'skip'"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "@types/vscode": "^1.85.0"
  },
  "dependencies": {
    "@fetchtype/core": "workspace:*",
    "@fetchtype/types": "workspace:*"
  }
}
